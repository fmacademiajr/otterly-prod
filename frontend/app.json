{
  "expo": {
    "name": "Otterly",
    "slug": "otterly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "otterly",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.emergent.otterlynext.u9tal9",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Otterly listens so you can capture tasks by voice."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5E8B82"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergent.otterlynext.u9tal9",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#F7F3EA"
        }
      ],
      "expo-web-browser",
      "expo-secure-store",
      "@sentry/react-native",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
